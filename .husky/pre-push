#!/bin/sh

branch_name=$(git rev-parse --abbrev-ref HEAD)

# Allowed format: type/issue_number/feature_name (snake_case)
branch_regex="^(feat|fix|build|chore|refactor|docs|perf|test|ci)/[0-9]+/[a-z0-9]+(_[a-z0-9]+)*$"

if ! echo "$branch_name" | grep -Eq "$branch_regex"; then
  echo "Invalid branch name. Expected format: type/issue_number/feature_name"
  echo "Allowed types: feat, fix, build, chore, refactor, docs, perf, test, ci"
  echo "Example: feat/167/swagger_documentation"
  echo "Use 'git branch -m new_branch_name' to rename your branch and try again."
  exit 1
fi

exit 0